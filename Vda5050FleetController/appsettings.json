{
  "ConnectionStrings": {
    "Fleet": "Host=localhost;Port=5432;Database=fleet_manager;Username=fleet;Password=fleet"
  },
  "Mqtt": {
    "Host":          "localhost",
    "Port":          1883,
    "ClientId":      "fleet-controller-01",
    "InterfaceName": "uagv",
    "MajorVersion":  "v2"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":            "Warning",
        "Microsoft.AspNetCore": "Warning",
        "LinqToDB":             "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
