# ─────────────────────────────────────────────────────────
# FleetManager – Umgebungsvariablen
# Kopiere diese Datei als .env (wird von docker-compose geladen)
# ─────────────────────────────────────────────────────────

# ASP.NET Core Umgebung (Development | Production)
ASPNETCORE_ENVIRONMENT=Development

# HTTP-Port des FleetControllers (extern erreichbar)
FLEET_HTTP_PORT=8080

# MQTT-Broker Einstellungen
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_CLIENT_ID=fleet-controller-01
MQTT_INTERFACE_NAME=uagv
MQTT_MAJOR_VERSION=v2
